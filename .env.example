# ── TreasureMap — root environment template ────────────────────────────────────
# Copy to .env and adjust as needed before running the application.
# The installers create this file automatically.

# Elasticsearch connection (no auth required for single-node dev setup)
ELASTICSEARCH_URL=http://localhost:9200

# Index name prefix — all indices will be treasuremap_<suffix>
ES_INDEX_PREFIX=treasuremap

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
